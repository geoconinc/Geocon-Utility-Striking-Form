# ============================================================
#  Copy this file to .env and fill in your actual values
# ============================================================

# ---- Azure Storage (Blob + Table) ----
# Find this in Azure Portal > Storage Account > Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net

# Container name for uploaded photos (auto-created if missing)
AZURE_BLOB_CONTAINER=utility-strike-photos

# Table name for form data (auto-created if missing)
AZURE_TABLE_NAME=UtilityStrikeReports

# ---- Email (SMTP) ----
# For Office 365 / Outlook:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@geoconinc.com
SMTP_PASS=your-email-password-or-app-password

# "From" address shown on the email
SMTP_FROM=your-email@geoconinc.com

# Recipients (comma-separated for multiple)
EMAIL_TO=miranda@geoconinc.com

# ---- Server ----
PORT=3000
