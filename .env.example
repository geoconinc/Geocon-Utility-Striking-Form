# Copy to .env and set your values. Form sends email via SMTP only (no database).

# ---- SMTP (e.g. Office 365) ----
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@geoconinc.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@geoconinc.com

# ---- Recipients ----
EMAIL_TO=mundra@Geoconinc.com
# LEGAL_EMAIL=legal@geoconinc.com

# ---- Server (optional) ----
PORT=3000
